---
import '../styles/styles.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'ペンギンタイムカード — インストールしたその日から使える、やさしい勤怠管理', description = '小さなお店・会社のための、インストール不要のやさしい勤怠管理アプリ。ICカードも機械も不要。今すぐ無料で始められます。' } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content={description} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;800;900&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet" />
		<style>
			/* tweak-driven utility classes */
			html.hide-mascot .mascot { display: none !important; }
			html.reduce-motion *, html.reduce-motion *::before, html.reduce-motion *::after {
				animation-duration: 0.001ms !important;
				animation-iteration-count: 1 !important;
				transition-duration: 0.001ms !important;
			}
		</style>
	</head>
	<body>
		<slot />
	</body>
</html>
