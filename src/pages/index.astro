	<script>
		(function() {
			const NAMES = [
				{ name: '田中', color: '#F39A2D' },
				{ name: '中村', color: '#7BC8E8' },
				{ name: '鈴木', color: '#6FBF73' },
				{ name: '山田', color: '#E66B7A' },
				{ name: '高橋', color: '#9B7BD8' },
				{ name: '渡辺', color: '#E2A93C' },
			];
			const peopleEl = document.getElementById('demoPeople');
			if (peopleEl) {
				NAMES.forEach((p, i) => {
					const el = document.createElement('div');
					el.className = 'demo-person';
					el.dataset.idx = String(i);
					el.innerHTML = `
						<span class="avatar" style="background:${p.color}">${p.name[0]}</span>
						<span class="who">${p.name}</span>
						<span class="stamp">--:--</span>
					`;
					peopleEl.appendChild(el);
				});
			}

			const hh = document.getElementById('hh');
			const mm = document.getElementById('mm');
			const ss = document.getElementById('ss');
			const dateEl = document.getElementById('demoDate');
			function pad(n: number) { return n < 10 ? '0' + n : '' + n; }
			function tick() {
				const d = new Date();
				if (hh) hh.textContent = pad(d.getHours());
				if (mm) mm.textContent = pad(d.getMinutes());
				if (ss) ss.textContent = pad(d.getSeconds());
				const wd = ['日', '月', '火', '水', '木', '金', '土'][d.getDay()];
				if (dateEl) dateEl.textContent = `${d.getFullYear()}.${pad(d.getMonth() + 1)}.${pad(d.getDate())} (${wd})`;
			}
			tick();
			setInterval(tick, 1000);

			const counter = document.getElementById('checkedCount');
			let stampOrder = [0, 1, 2, 3, 4, 5];
			let cursor = 0;
			function shuffle(a: number[]) {
				for (let i = a.length - 1; i > 0; i--) {
					const j = Math.floor(Math.random() * (i + 1));
					[a[i], a[j]] = [a[j], a[i]];
				}
				return a;
			}

			function doStamp() {
				if (!peopleEl || document.documentElement.classList.contains('reduce-motion')) return;
				const allDone = peopleEl.querySelectorAll('.demo-person.checked').length === NAMES.length;
				if (allDone) {
					peopleEl.querySelectorAll('.demo-person').forEach((el) => el.classList.remove('checked'));
					peopleEl.querySelectorAll('.demo-person .stamp').forEach((el) => {
						el.textContent = '--:--';
					});
					if (counter) counter.textContent = '0';
					cursor = 0;
					stampOrder = shuffle([0, 1, 2, 3, 4, 5]);
					return;
				}
				const idx = stampOrder[cursor++ % NAMES.length];
				const target = peopleEl.querySelector(`.demo-person[data-idx="${idx}"]`) as HTMLElement | null;
				if (!target || target.classList.contains('checked')) return;

				const pulse = document.createElement('span');
				pulse.className = 'tap-pulse';
				const rect = target.getBoundingClientRect();
				pulse.style.left = rect.width / 2 - 4 + 'px';
				pulse.style.top = rect.height / 2 - 4 + 'px';
				target.style.position = 'relative';
				target.appendChild(pulse);
				setTimeout(() => pulse.remove(), 800);

				target.classList.add('checked');
				const now = new Date();
				const t = pad(now.getHours()) + ':' + pad(now.getMinutes());
				const stampEl = target.querySelector('.stamp') as HTMLElement | null;
				if (stampEl) stampEl.textContent = t;
				if (counter) counter.textContent = String(peopleEl.querySelectorAll('.demo-person.checked').length);
			}
			setTimeout(() => {
				stampOrder = shuffle([0, 1, 2, 3, 4, 5]);
				setInterval(doStamp, 1700);
			}, 800);

			const countNums = document.querySelectorAll('[data-target]');
			const countObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (!entry.isIntersecting) return;
					const el = entry.target as HTMLElement;
					const target = parseInt(el.dataset.target || '0', 10) || 0;
					const dur = 1400;
					const start = performance.now();
					function step(now: number) {
						const t = Math.min(1, (now - start) / dur);
						const eased = 1 - Math.pow(1 - t, 3);
						el.textContent = String(Math.round(target * eased));
						if (t < 1) requestAnimationFrame(step);
					}
					requestAnimationFrame(step);
					countObserver.unobserve(el);
				});
			}, { threshold: 0.3 });
			countNums.forEach((n) => countObserver.observe(n));

			const revealObserver = new IntersectionObserver((entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add('in');
						revealObserver.unobserve(entry.target);
					}
				});
			}, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
			document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));

			const floats = document.querySelectorAll<HTMLElement>('.float');
			const heroPenguin = document.querySelector<HTMLElement>('.hero-penguin-big');
			window.addEventListener('scroll', () => {
				if (document.documentElement.classList.contains('reduce-motion')) return;
				const y = window.scrollY;
				floats.forEach((el, i) => {
					el.style.transform = `translateY(${y * (i % 2 ? -0.15 : 0.1)}px)`;
				});
				if (heroPenguin) {
					heroPenguin.style.transform = `translateY(${y * -0.05}px)`;
				}
			}, { passive: true });
		})();
	</script>
