---
import Layout from '../layouts/Layout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageCta from '../components/PageCta.astro';

const title = '料金 — ペンギンタイムカード';
const description = '料金プラン比較';
---

<Layout title={title} description={description}>
	<SiteHeader active="rate" />

	<section class="rate-hero" data-screen-label="02 Rate Hero">
		<div class="rate-hero-bg"></div>
		<div class="container rate-hero-inner">
			<span class="eyebrow">RATE PLAN</span>
			<h1>
				人数に合わせて、<br />
				<span class="accent">5つのプラン</span>。
			</h1>
			<p class="lead">
				料金は人数によって以下の5つのプランに分かれています。<br />
				まずは1ヶ月無料、合わなければ何もしなくてOKです。
			</p>
			<div class="hero-actions">
				<a class="btn btn-primary" href="https://m.tc-timecard.com/?page=payment">
					お支払い画面へ
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
				</a>
				<a class="btn btn-ghost" href="#plans">プランを比較する</a>
			</div>
			<div class="blue-link">
				ブルー版のお支払いは
				<a href="/news/free-plan-payment/">こちら</a>
			</div>
		</div>
	</section>

	<section class="section plans-section" id="plans" data-screen-label="03 Plans">
		<div class="container">
			<div class="section-head reveal">
				<span class="eyebrow">PLANS</span>
				<h2><span class="mark">5種類</span>のペンギンから選ぶ</h2>
				<p class="lead">小さなお店から、50人規模のオフィスまで。階段のように広がる料金体系です。</p>
			</div>

			<div class="plans-grid">
				<div class="plan-card p1 reveal">
					<div class="plan-penguin size-1"><img src="/assets/penguin.png" alt="マイクロペンギン" /></div>
					<div class="plan-jp">マイクロ<br />ペンギン</div>
					<div class="plan-alias">MICRO</div>
					<div class="plan-price"><span class="amount">1,210</span><span class="yen">円</span><span class="per">/月</span></div>
					<div class="plan-spec">
						<div class="plan-spec-row"><span class="lbl">スタッフ数上限</span><span class="val">5人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証登録</span><span class="val dash">―</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証</span><span class="val dash">なし</span></div>
					</div>
				</div>

				<div class="plan-card p2 reveal">
					<div class="plan-penguin size-2"><img src="/assets/penguin.png" alt="コガタペンギン" /></div>
					<div class="plan-jp">コガタ<br />ペンギン</div>
					<div class="plan-alias">MINI</div>
					<div class="plan-price"><span class="amount">2,200</span><span class="yen">円</span><span class="per">/月</span></div>
					<div class="plan-spec">
						<div class="plan-spec-row"><span class="lbl">スタッフ数上限</span><span class="val">15人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証登録</span><span class="val">10人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証</span><span class="check">✓</span></div>
					</div>
				</div>

				<div class="plan-card p3 featured reveal">
					<div class="plan-ribbon">人気プラン</div>
					<div class="plan-penguin size-3"><img src="/assets/penguin.png" alt="アデリーペンギン" /></div>
					<div class="plan-jp">アデリー<br />ペンギン</div>
					<div class="plan-alias">SMALL</div>
					<div class="plan-price"><span class="amount">3,850</span><span class="yen">円</span><span class="per">/月</span></div>
					<div class="plan-spec">
						<div class="plan-spec-row"><span class="lbl">スタッフ数上限</span><span class="val">25人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証登録</span><span class="val">17人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証</span><span class="check">✓</span></div>
					</div>
				</div>

				<div class="plan-card p4 reveal">
					<div class="plan-penguin size-4"><img src="/assets/penguin.png" alt="オウサマペンギン" /></div>
					<div class="plan-jp">オウサマ<br />ペンギン</div>
					<div class="plan-alias">MEDIUM</div>
					<div class="plan-price"><span class="amount">5,500</span><span class="yen">円</span><span class="per">/月</span></div>
					<div class="plan-spec">
						<div class="plan-spec-row"><span class="lbl">スタッフ数上限</span><span class="val">35人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証登録</span><span class="val">25人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証</span><span class="check">✓</span></div>
					</div>
				</div>

				<div class="plan-card p5 reveal">
					<div class="plan-penguin size-5"><img src="/assets/penguin.png" alt="コウテイペンギン" /></div>
					<div class="plan-jp">コウテイ<br />ペンギン</div>
					<div class="plan-alias">LARGE</div>
					<div class="plan-price"><span class="amount">8,250</span><span class="yen">円</span><span class="per">/月</span></div>
					<div class="plan-spec">
						<div class="plan-spec-row"><span class="lbl">スタッフ数上限</span><span class="val">50人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証登録</span><span class="val">35人</span></div>
						<div class="plan-spec-row"><span class="lbl">顔認証</span><span class="check">✓</span></div>
					</div>
				</div>
			</div>

			<p class="tax-note">※ 上記はすべて税込価格です。</p>
		</div>
	</section>

	<section class="section matrix-section" data-screen-label="04 Matrix">
		<div class="container">
			<div class="section-head reveal">
				<span class="eyebrow">FEATURE MATRIX</span>
				<h2>すべてのプランで<span class="mark">使える機能</span></h2>
				<p class="lead">プランによって異なるのは「人数」と「顔認証」だけ。あとの主要機能はぜんぶ共通で使えます。</p>
			</div>

			<div class="matrix-wrap reveal">
				<table class="matrix-table">
					<thead>
						<tr>
							<th class="row-label" style="text-align:left;">機能</th>
							<th>マイクロ<span class="alias-tag">MICRO</span></th>
							<th>コガタ<span class="alias-tag">MINI</span></th>
							<th>アデリー<span class="alias-tag">SMALL</span></th>
							<th>オウサマ<span class="alias-tag">MEDIUM</span></th>
							<th>コウテイ<span class="alias-tag">LARGE</span></th>
						</tr>
					</thead>
					<tbody>
						<tr><td class="row-label">月額（税込）</td><td><b>1,210円</b></td><td><b>2,200円</b></td><td><b>3,850円</b></td><td><b>5,500円</b></td><td><b>8,250円</b></td></tr>
						<tr><td class="row-label">スタッフ数上限</td><td>5人</td><td>15人</td><td>25人</td><td>35人</td><td>50人</td></tr>
						<tr><td class="row-label">顔認証登録</td><td><span class="dash-mark">―</span></td><td>10人</td><td>17人</td><td>25人</td><td>35人</td></tr>
						<tr><td class="row-label">顔認証</td><td><span class="dash-mark">なし</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td></tr>
						<tr><td class="row-label">WEBレポート</td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td></tr>
						<tr><td class="row-label">出退勤記録のメール送信</td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td></tr>
						<tr><td class="row-label">複数オフィス</td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td></tr>
						<tr><td class="row-label">スタッフによるログイン</td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td><td><span class="check-mark">✓</span></td></tr>
					</tbody>
				</table>
			</div>
		</div>
	</section>

	<section class="section trial-section" data-screen-label="05 Trial">
		<div class="container">
			<div class="section-head reveal">
				<span class="eyebrow">FREE TRIAL</span>
				<h2>無料お試し<span class="mark">期間について</span></h2>
			</div>

			<div class="trial-card reveal">
				<div>
					<h2>１ヶ月無料</h2>
					<p>アカウント登録から１ヶ月は無料でお試しいただけます。</p>
					<p>無料期間が終了すると、新たに出勤・退勤のボタンが押せなくなります。継続して利用する場合は、お支払い画面からお手続きをお願いします。</p>
					<div class="note"><span class="icon">!</span><span><b>※ご安心ください。</b><br/>無料期間が終了しても、勝手に課金されることはございません。アカウントを完全削除したい方はマニュアルをご参照ください。</span></div>
				</div>
				<div class="stamp-circle"><div><div class="num">1</div><div class="lbl">MONTH</div><div class="lbl-big">無料</div></div></div>
			</div>
		</div>
	</section>

	<section class="section other-plans-section" data-screen-label="06 Other Plans">
		<div class="container">
			<div class="section-head reveal">
				<span class="eyebrow">OTHER PLANS</span>
				<h2>その他の<span class="mark">プラン</span></h2>
			</div>

			<div class="other-plans">
				<div class="other-card coming reveal">
					<img class="pen-corner" src="/assets/penguin.png" alt="" />
					<span class="other-tag">PAY-AS-YOU-GO</span>
					<h3>マカロニペンギン</h3>
					<div class="sub">従量プラン</div>
					<span class="preparing">（準備中）</span>
					<p>人数ではなく、<b>出勤日数</b>を元に計算するプランです。月に数日しか出勤しないパート従業員が多い会社に向いています。</p>
					<p style="font-size:13px;">現在機能開発中です。もう少々お待ちください。<br/>ベータ版でお試ししたい方はお問い合わせください。</p>
					<a class="btn btn-ghost other-btn" href="/contact-us/" style="padding:12px 22px; font-size:14px;">お問い合わせ</a>
				</div>

				<div class="other-card reveal">
					<img class="pen-corner" src="/assets/penguin.png" alt="" />
					<span class="other-tag">ENTERPRISE</span>
					<h3>法人向けプラン</h3>
					<div class="sub">中・大規模企業向け</div>
					<p>50人以上の企業や、占有サーバーがほしい方、追加機能がほしい方などが対象です。</p>
					<p style="font-size:13px;">AIによる顔認証など、独自開発にもお答えいたします。</p>
					<a class="btn btn-primary other-btn" href="/corporation/" style="padding:12px 22px; font-size:14px;">法人向けプランを見る<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg></a>
				</div>
			</div>
		</div>
	</section>

	<section class="section payment-section" id="payment" data-screen-label="07 Payment">
		<div class="container">
			<div class="section-head reveal">
				<span class="eyebrow">HOW TO PAY</span>
				<h2>お支払いの<span class="mark">手順</span></h2>
				<p class="lead">お支払いは「管理者メニュー」→「プラン更新・お支払い」からお手続きください。</p>
			</div>

			<div class="payment-callout reveal">
				<span class="warn-icon">!</span>
				<div class="text"><b>注意：</b>iPad、iPhone、Androidアプリではお支払いできません。<br/>必ず「お支払い画面へ」ボタンからWEB画面にてお支払いください。</div>
			</div>

			<div class="steps-list">
				<div class="pay-step reveal"><div class="num">1</div><div><h4>こちらへログインします</h4><p><a href="https://m.tc-timecard.com/?page=payment">https://m.tc-timecard.com/?page=payment</a></p></div></div>
				<div class="pay-step reveal"><div class="num">2</div><div><h4>右上の「管理画面」をクリックします</h4><p>ログイン後、右上に表示される「管理画面」のボタンを押してください。</p></div></div>
				<div class="pay-step reveal"><div class="num">3</div><div><h4>「プラン更新・お支払い」をクリックします</h4><p>管理画面のメニューから、お支払いに進みます。</p></div></div>
				<div class="pay-step reveal"><div class="num">4</div><div><h4>該当プランの「選択」をクリックします</h4><p>5つのペンギンプランの中から、人数に合ったものを選んでください。</p></div></div>
				<div class="pay-step reveal"><div class="num">5</div><div><h4>お支払い方法を選択してください</h4><p>口座振替の場合は銀行側のお手続きに数ヶ月かかってしまうため、お急ぎの場合はクレジットカードを選択してください。</p></div></div>
				<div class="pay-step reveal"><div class="num">6</div><div><h4>クレジットカード情報を入れ、「〇〇プランに変更する」を押してください</h4><p>お手続きは以上です。お使いのアプリでも継続して出勤、退勤ボタンが押せるようになります。引き続きエラーとなる場合は、一度アプリを落としていただくか、ログアウトして再度ログインしてください。</p></div></div>
			</div>
		</div>
	</section>

	<section class="section methods-section" data-screen-label="08 Methods">
		<div class="container">
			<div class="section-head reveal">
				<span class="eyebrow">PAYMENT METHODS</span>
				<h2><span class="mark">2つ</span>の支払い方法</h2>
				<p class="lead">お支払いには「クレジットカード」「口座引落」の２つをご用意しています。</p>
			</div>
			<div class="methods">
				<div class="method-card m-card reveal">
					<div class="method-icon">
						<svg width="36" height="36" viewBox="0 0 60 60" aria-hidden="true">
							<rect x="6" y="14" width="48" height="32" rx="4" fill="#fff" stroke="#1F1A17" stroke-width="2.5"/>
							<rect x="6" y="20" width="48" height="6" fill="var(--brand)"/>
							<rect x="12" y="34" width="14" height="3" fill="#1F1A17"/>
							<rect x="12" y="40" width="22" height="3" fill="#6B5E52"/>
							<rect x="40" y="34" width="10" height="9" rx="1.5" fill="var(--brand-soft)" stroke="#1F1A17" stroke-width="1.5"/>
						</svg>
					</div>
					<h3>クレジットカード</h3>
					<p>毎月、クレジットカードにご請求させていただきます。お支払い後、アプリが即時に有効化されます。</p>
					<div class="meta-line">※弊社のクレジットカード支払いは、<a href="https://stripe.com/jp/about">米国Stripe社</a>のシステムを採用しております。お客様のクレジットカード情報はStripe社のサーバーにて安全に管理され、弊社サーバーに残ることはございません。</div>
				</div>
				<div class="method-card m-bank reveal">
					<div class="method-icon">
						<svg width="36" height="36" viewBox="0 0 60 60" aria-hidden="true">
							<path d="M8 22 L30 10 L52 22 L52 26 L8 26 Z" fill="#fff" stroke="#1F1A17" stroke-width="2.5" stroke-linejoin="round"/>
							<rect x="14" y="28" width="4" height="16" fill="var(--sky)"/>
							<rect x="22" y="28" width="4" height="16" fill="var(--sky)"/>
							<rect x="30" y="28" width="4" height="16" fill="var(--sky)"/>
							<rect x="38" y="28" width="4" height="16" fill="var(--sky)"/>
							<rect x="6" y="46" width="48" height="4" fill="#1F1A17"/>
						</svg>
					</div>
					<h3>口座引き落とし</h3>
					<p>弊社より口座振替依頼書を郵送でお送りします。ご記入の上、銀行印を押し、ご返送ください。</p>
					<div class="alert">⚠️ 口座引き落としが開始されるまで、銀行手続きの都合により<b>２〜3ヶ月かかります</b>。</div>
					<p style="font-size:13px;">その間はクレジットカードでお支払いいただくか、口座振込によりお振り込みをお願いしております。振込先の口座は、口座引き落としをお申し込み時に送信されるメールに記載しております。お急ぎの方はクレジットカードをご利用ください。</p>
				</div>
			</div>
		</div>
	</section>

	<PageCta
		eyebrow="START NOW"
		title="まずは1ヶ月、<br/>無料で試してみませんか？"
		description="クレジットカード登録は不要。合わなければ、何もしなくて大丈夫です。<br/>勝手に課金されることは、もちろんありません。"
		buttonText="お支払い画面へ"
		buttonHref="https://m.tc-timecard.com/?page=payment"
		meta="いつでも解約OK ／ 安心してお試しください"
		screenLabel="09 CTA"
	/>

	<SiteFooter />
</Layout>

<style>
	.rate-hero { position: relative; padding: 80px 0 60px; overflow: hidden; }
	.rate-hero-bg {
		position: absolute; inset: 0;
		background:
			radial-gradient(ellipse 70% 60% at 80% 20%, rgba(243, 154, 45, 0.14), transparent 60%),
			radial-gradient(ellipse 60% 50% at 12% 80%, rgba(123, 200, 232, 0.16), transparent 60%);
		pointer-events: none;
	}
	.rate-hero-inner { text-align: center; position: relative; }
	.rate-hero h1 { font-size: 56px; letter-spacing: -0.015em; margin: 14px 0 22px; }
	@media (max-width: 900px) { .rate-hero h1 { font-size: 44px; } }
	@media (max-width: 640px) { .rate-hero h1 { font-size: 36px; } }
	.rate-hero h1 .accent { color: var(--brand-deep); position: relative; display: inline-block; }
	.rate-hero h1 .accent::after {
		content: ""; position: absolute; left: 0; right: 0; bottom: -4px; height: 8px;
		background: var(--brand-soft); border-radius: 999px; z-index: -1;
	}
	.rate-hero p.lead { font-size: 18px; color: var(--ink-2); max-width: 640px; margin: 0 auto 32px; }
	.rate-hero .hero-actions { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
	.rate-hero .blue-link { margin-top: 26px; font-size: 14px; color: var(--ink-2); font-weight: 700; }
	.rate-hero .blue-link a { color: var(--brand-deep); border-bottom: 2px dotted var(--brand-deep); }

	.plans-section { padding: 80px 0 120px; }
	.plans-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 16px; margin-top: 60px; align-items: end; }
	@media (max-width: 1080px) { .plans-grid { grid-template-columns: repeat(2, 1fr); gap: 28px; } }
	@media (max-width: 540px) { .plans-grid { grid-template-columns: 1fr; } }
	.plan-card {
		background: white; border-radius: 24px; border: 2px solid var(--line); box-shadow: var(--shadow);
		padding: 28px 20px 24px; text-align: center; position: relative; transition: transform .35s cubic-bezier(.2,.7,.2,1);
	}
	.plan-card:hover { transform: translateY(-8px); }
	@media (min-width: 1081px) {
		.plan-card.p1 { transform: translateY(48px); }
		.plan-card.p2 { transform: translateY(36px); }
		.plan-card.p3 { transform: translateY(24px); }
		.plan-card.p4 { transform: translateY(12px); }
		.plan-card.p5 { transform: translateY(0); }
		.plan-card.p1:hover { transform: translateY(40px); }
		.plan-card.p2:hover { transform: translateY(28px); }
		.plan-card.p3:hover { transform: translateY(16px); }
		.plan-card.p4:hover { transform: translateY(4px); }
		.plan-card.p5:hover { transform: translateY(-8px); }
	}
	.plan-card.featured { border-color: var(--brand); box-shadow: 0 24px 48px -20px rgba(226, 125, 23, 0.45); }
	.plan-ribbon {
		position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: var(--brand); color: white;
