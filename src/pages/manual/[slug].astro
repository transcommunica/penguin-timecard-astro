---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import SiteHeader from '../../components/SiteHeader.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const WP_MANUAL_ENDPOINT = 'https://tc-timecard.com/wp-json/wp/v2/pages?parent=2887&per_page=100';

type WpPage = {
  id: number;
  slug: string;
  menu_order: number;
  date: string;
  modified: string;
  title: { rendered: string };
  excerpt: { rendered: string };
  content: { rendered: string };
};

type ManualMdFrontmatter = {
  title: string;
  description: string;
  category: 'overview' | 'settings' | 'behavior' | 'billing';
  itemCode: string;
};

type ManualMdModule = {
  frontmatter: ManualMdFrontmatter;
  Content: Awaited<ReturnType<typeof render>>['Content'];
};

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();
const localizeWpUploads = (html: string) =>
  html.replace(/https?:\/\/tc-timecard\.com\/wp-content\/uploads\//g, '/assets/manual/');

const decodeEntities = (text: string) =>
  text
    .replaceAll('&nbsp;', ' ')
    .replaceAll('&#8230;', '…')
    .replaceAll('&hellip;', '…')
    .replaceAll('&amp;', '&')
    .replaceAll('&quot;', '"')
    .replaceAll('&#039;', "'");

const tidyWpText = (html: string) => {
  const normalized = decodeEntities(stripHtml(html))
    .replace(/\[\s*…\s*\]\s*続きを読む\s*/gi, '')
    .replace(/続きを読む\s*/gi, '')
    .replace(/\s*\(続きを読む\)\s*/gi, '')
    .replace(/\s*read\s+more\s*$/gi, '')
    .replace(/(\.\.\.|…)\s*$/g, '')
    .replace(/\s+/g, ' ')
    .trim();

  return normalized;
};

const cleanManualDescription = (text: string) =>
  String(text || '')
    .replace(/\[\s*…\s*\]/g, ' ')
    .replace(/続きを読む(?:…|\.\.\.)?\s*from\s.*$/i, '')
    .replace(/よくある質問[\s\S]*$/i, '')
    .replace(/\s+/g, ' ')
    .trim();

const getFirstParagraphHtml = (html: string) => {
  const match = html.match(/<p[^>]*>([\s\S]*?)<\/p>/i);
  return match ? match[1] : html;
};

const extractContentBlocks = (html: string) => {
  const blockMatches = [...html.matchAll(/<(p|li|h2|h3)[^>]*>([\s\S]*?)<\/\1>/gi)];
  const blocks = blockMatches
    .map((match) => tidyWpText(match[2]))
    .filter((text) => text.length > 0);

  if (blocks.length > 0) {
    return blocks;
  }

  const fallback = tidyWpText(html);
  return fallback ? [fallback] : [];
};

const extractH2Topics = (contentHtml: string, pageTitle: string) => {
  const titleNormalized = tidyWpText(pageTitle).replace(/\s+/g, '');

  const h2Matches = [...contentHtml.matchAll(/<h2[^>]*>([\s\S]*?)<\/h2>/gi)];
  const h2Topics = h2Matches
    .map((match) => tidyWpText(match[1]))
    .map((text) => text.replace(/^\d+[\.．、)）]?\s*/, '').trim())
    .filter((text) => text.length >= 2)
    .filter((text) => text.replace(/\s+/g, '') !== titleNormalized)
    .filter((text, index, arr) => arr.indexOf(text) === index);

  if (h2Topics.length >= 2) {
    return h2Topics;
  }

  const allMatches = [...contentHtml.matchAll(/<(h2|h3)[^>]*>([\s\S]*?)<\/\1>/gi)];
  return allMatches
    .map((match) => tidyWpText(match[2]))
    .map((text) => text.replace(/^\d+[\.．、)）]?\s*/, '').trim())
    .filter((text) => text.length >= 2)
    .filter((text) => text.replace(/\s+/g, '') !== titleNormalized)
    .filter((text, index, arr) => arr.indexOf(text) === index);
};

const isMetadataLine = (text: string) =>
  /^(所要時間|バージョン|更新日時|最終更新|作成日|January|February|March|April|May|June|July|August|September|October|November|December|\d{4}年\d{1,2}月|版|v\d+\.\d+)/.test(
    text
  );

const isGenericTopic = (topic: string) => {
  const generic = /^(注意点|注意|設定|方法|手順|やり方|確認|一覧|基本|詳細|その他)$/;
  return generic.test(topic);
};

const buildCoreDescription = (_excerptHtml: string, contentHtml: string, pageTitle: string) => {
  const topics = extractH2Topics(contentHtml, pageTitle);

  // Spread sampling: first, mid, last
  const spread: string[] = [];
  if (topics.length >= 1) spread.push(topics[0]);
  if (topics.length >= 3) spread.push(topics[Math.floor((topics.length - 1) / 2)]);
  if (topics.length >= 2) spread.push(topics[topics.length - 1]);
  const unique = spread.filter((t, i, a) => a.indexOf(t) === i);

  if (unique.length >= 3) {
    const topicList = unique.slice(0, 3).join('・');
    return `${topicList}など、関連する操作・設定を確認できます`;
  }

  if (unique.length === 2) {
    const [a, b] = unique;
    return `${a}と${b}をまとめて確認できます`;
  }

  if (unique.length === 1) {
    const topic = unique[0];
    if (isGenericTopic(topic)) {
      return `${pageTitle}の${topic}について詳しく確認できます`;
    }
    return `${topic}について詳しく確認できます`;
  }

  // No headings: scan paragraphs for descriptive content
  const titleText = tidyWpText(pageTitle);
  const pMatches = [...contentHtml.matchAll(/<p[^>]*>([\s\S]*?)<\/p>/gi)];
  const validParas: string[] = [];
  for (const [, inner] of pMatches) {
    const raw = (() => {
      const t = tidyWpText(inner);
      const safe = titleText.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
      return t.replace(new RegExp(`^${safe}\\s*`, 'i'), '').trim();
    })();
    
    if (raw.length < 20) continue;
    if (isMetadataLine(raw)) continue;
    if (/^(まず[、,]|次に[、,]|\d+[.、)）])/.test(raw)) continue;
    validParas.push(raw);
  }

  // Combine first 2-3 valid paragraphs for richer description
  if (validParas.length >= 2) {
    const combined = validParas.slice(0, 3).join('');
    if (combined.length > 30) {
      return combined;
    }
  }

  // Use first longest valid paragraph
  if (validParas.length > 0) {
    const sorted = [...validParas].sort((a, b) => b.length - a.length);
    for (const para of sorted) {
      const jp = para.indexOf('。');
      if (jp > 16) return para.slice(0, jp + 1);
      if (para.length >= 20) return para;
    }
  }

  return `「${pageTitle}」の設定手順と使い方をまとめています`;
};

const buildWpLead = (excerptHtml: string, contentHtml: string, pageTitle: string) => {
  const core = buildCoreDescription(excerptHtml, contentHtml, pageTitle);
  return `このページでは、${core}。`;
};

const fetchWpManualPages = async (): Promise<WpPage[]> => {
  try {
    const response = await fetch(WP_MANUAL_ENDPOINT, {
      headers: { Accept: 'application/json' },
    });

    if (!response.ok) {
      return [];
    }

    const payload = (await response.json()) as unknown;
    if (!Array.isArray(payload)) {
      return [];
    }

    return payload as WpPage[];
  } catch {
    return [];
  }
};

export async function getStaticPaths() {
  const entries = await getCollection('manual');
  const canonicalPaths = entries.map((item) => ({
    params: {
      slug: item.id.replace(/\.md$/, ''),
    },
  }));

  // Static output only generates routes returned here, so include legacy WP slugs.
  const legacyAliasToLocalSlug: Record<string, string> = {
    'auto-overnight': 'auto-next-day',
    'face-recognition-overview': 'face-auth-overview',
    'face-recognition': 'face-auth',
    'add-user': 'owner-account',
    'add-staff': 'staff-account',
    'display-input-only-account': 'limited-account',
    'permission-edit-time': 'lock-edit-time',
    'skip-work-detail': 'skip-detail-after-stamp',
    'password-protection': 'admin-password',
    'holiday-setting': 'holiday-settings',
    'morning-overtime': 'early-overtime',
    'closind-date': 'closing-day',
    'unsubscribe': 'delete-account',
    'cancel-subscription': 'cancel-subscription',
    'subscribe': 'billing',
    'basic-how-to-use': 'basic-usage',
    'multiple-breaks': 'multi-break',
    'shifts': 'shift-management',
    'overnight24': 'open-24h',
    'overnight1': 'midnight-operation',
    'slack': 'slack-integration',
    'category-pattern-setting': 'category-patterns',
    'memo': 'memo-feature',
    'screensaver': 'screensaver',
    'open-24-hours': 'open-24h',
    'open-24-hour': 'open-24h',
    '24-hour-operation': 'open-24h',
    '24-hours-operation': 'open-24h',
    '24hour-operation': 'open-24h',
    '24h-operation': 'open-24h',
    'multiple-break': 'multi-break',
    'multiple-break-support': 'multi-break',
    'late-night-operation': 'midnight-operation',
    'night-shift-operation': 'midnight-operation',
  };

  const localSlugSet = new Set(canonicalPaths.map((path) => path.params.slug));
  const aliasPaths = Object.entries(legacyAliasToLocalSlug)
    .filter(([alias, localSlug]) => alias !== localSlug && localSlugSet.has(localSlug))
    .map(([alias]) => ({ params: { slug: alias } }));

  return [...canonicalPaths, ...aliasPaths];
}

const { slug } = Astro.params;
const wpPages = (await fetchWpManualPages()).sort((a, b) => {
  const leftOrder = typeof a.menu_order === 'number' ? a.menu_order : 0;
  const rightOrder = typeof b.menu_order === 'number' ? b.menu_order : 0;
  if (leftOrder !== rightOrder) {
    return leftOrder - rightOrder;
  }

  return new Date(a.date).getTime() - new Date(b.date).getTime();
});
const wpPage = slug ? wpPages.find((item) => item.slug === slug) : undefined;

const entries = await getCollection('manual');
const sortedEntries = [...entries].sort((a, b) => a.data.order - b.data.order);
const entryBySlug = slug ? entries.find((item) => item.id.replace(/\.md$/, '') === slug) : undefined;

const normalizeManualTitle = (text: string) =>
  tidyWpText(text)
    .replace(/（概要）/g, 'の概要')
    .replace(/\(概要\)/g, 'の概要')
    .replace(/\s+/g, '')
    .trim();

const wpSlugToLocalFile: Record<string, string> = {
  'auto-overnight': 'auto-next-day',
  'face-recognition-overview': 'face-auth-overview',
  'face-recognition': 'face-auth',
  'add-user': 'owner-account',
  'add-staff': 'staff-account',
  'display-input-only-account': 'limited-account',
  'permission-edit-time': 'lock-edit-time',
  'skip-work-detail': 'skip-detail-after-stamp',
  'password-protection': 'admin-password',
  'holiday-setting': 'holiday-settings',
  'morning-overtime': 'early-overtime',
  'closind-date': 'closing-day',
  'rounding': 'rounding',
  'unsubscribe': 'delete-account',
  'cancel-subscription': 'cancel-subscription',
  'subscribe': 'billing',
  'basic-how-to-use': 'basic-usage',
  'multiple-breaks': 'multi-break',
  'shifts': 'shift-management',
  'overnight24': 'open-24h',
  'overnight1': 'midnight-operation',
  'slack': 'slack-integration',
  'category-pattern-setting': 'category-patterns',
  'memo': 'memo-feature',
  'screensaver': 'screensaver',
};

const manualSlugAliases: Record<string, string> = {
  ...wpSlugToLocalFile,
  'open-24-hours': 'open-24h',
  'open-24-hour': 'open-24h',
  '24-hour-operation': 'open-24h',
  '24-hours-operation': 'open-24h',
  '24hour-operation': 'open-24h',
  '24h-operation': 'open-24h',
  'multiple-break': 'multi-break',
  'multiple-break-support': 'multi-break',
  'late-night-operation': 'midnight-operation',
  'night-shift-operation': 'midnight-operation',
};

const normalizeManualSlug = (value: string) => {
  const raw = String(value || '').trim().replace(/^\/+|\/+$/g, '');
  let decoded = raw;
  try {
    decoded = decodeURIComponent(raw);
  } catch {
    decoded = raw;
  }
  return decoded
    .toLowerCase()
    .replace(/[_\s]+/g, '-')
    .replace(/-{2,}/g, '-')
    .replace(/^-+|-+$/g, '');
};

const aliasMap = new Map<string, string>();
const registerAlias = (from: string, to: string) => {
  const fromNorm = normalizeManualSlug(from);
  const toNorm = normalizeManualSlug(to);
  if (!fromNorm || !toNorm) return;
  aliasMap.set(fromNorm, toNorm);
  aliasMap.set(fromNorm.replace(/-/g, ''), toNorm);
};

for (const entry of entries) {
  const entrySlug = entry.id.replace(/\.md$/, '');
  registerAlias(entrySlug, entrySlug);
}
for (const [from, to] of Object.entries(manualSlugAliases)) {
  registerAlias(from, to);
}

const resolveManualSlug = (value: string | undefined) => {
  const norm = normalizeManualSlug(String(value || ''));
  if (!norm) return undefined;

  const direct = aliasMap.get(norm) || aliasMap.get(norm.replace(/-/g, ''));
  if (direct) return direct;

  if (/24\s*hour|24h|24-hours|24-hour/.test(norm) && /(open|operation|overnight|business)/.test(norm)) {
    return 'open-24h';
  }

  return norm;
};

const localMetaBySlug = new Map(
  entries.map((item) => [
    item.id.replace(/\.md$/, ''),
    {
      category: item.data.category,
      itemCode: item.data.itemCode,
    },
  ]),
);

const localMetaByTitle = new Map(
  entries.map((item) => [
    normalizeManualTitle(item.data.title),
    {
      category: item.data.category,
      itemCode: item.data.itemCode,
    },
  ]),
);

const manualMdModules = import.meta.glob('../../content/manual/*.md', { eager: true }) as Record<string, ManualMdModule>;
const manualMdBySlug = new Map(
  Object.entries(manualMdModules).map(([path, mod]) => [path.split('/').pop()?.replace(/\.md$/, '') ?? '', mod]),
);
const manualMdByTitle = new Map(
  Object.values(manualMdModules).map((mod) => [normalizeManualTitle(mod.frontmatter.title), mod]),
);

const mappedSlug = resolveManualSlug(slug);
const entryByMappedSlug = mappedSlug
  ? entries.find((item) => item.id.replace(/\.md$/, '') === mappedSlug)
  : undefined;
const entryByWpTitle = wpPage
  ? entries.find((item) => normalizeManualTitle(item.data.title) === normalizeManualTitle(stripHtml(wpPage.title.rendered)))
  : undefined;
const entry = entryBySlug ?? entryByMappedSlug ?? entryByWpTitle;

const mdBySlug = slug ? manualMdBySlug.get(slug) : undefined;
const mdByMappedSlug = mappedSlug ? manualMdBySlug.get(mappedSlug) : undefined;
const mdByWpTitle = wpPage ? manualMdByTitle.get(normalizeManualTitle(stripHtml(wpPage.title.rendered))) : undefined;
const mdModule = mdBySlug ?? mdByMappedSlug ?? mdByWpTitle;

const isWpManual = Boolean(wpPage) && !Boolean(entry) && !Boolean(mdModule);

if (!wpPage && !entry && !mdModule) {
  return Astro.redirect('/manual/');
}

const currentIndex = isWpManual
  ? wpPages.findIndex((item) => item.slug === wpPage?.slug)
  : sortedEntries.findIndex((item) => item.id === entry?.id);

const prevWpPage = isWpManual && currentIndex > 0 ? wpPages[currentIndex - 1] : undefined;
const nextWpPage = isWpManual && currentIndex >= 0 && currentIndex < wpPages.length - 1 ? wpPages[currentIndex + 1] : undefined;

const prevEntry = !isWpManual && currentIndex > 0 ? sortedEntries[currentIndex - 1] : undefined;
const nextEntry = !isWpManual && currentIndex >= 0 && currentIndex < sortedEntries.length - 1 ? sortedEntries[currentIndex + 1] : undefined;

let Content: Awaited<ReturnType<typeof render>>['Content'] | undefined;
if (entry) {
  const rendered = await render(entry);
  Content = rendered.Content;
} else if (mdModule) {
  Content = mdModule.Content;
}

const categoryLabelMap = {
  overview: '概要',
  settings: '設定',
  behavior: '動作関連',
  billing: 'お支払い・解約',
} as const;

const categoryEnMap = {
  overview: 'OVERVIEW',
  settings: 'SETTINGS',
  behavior: 'BEHAVIOR',
  billing: 'BILLING',
} as const;

type ManualCategory = keyof typeof categoryLabelMap;

const wpSlugToCategory: Record<string, ManualCategory> = {
  'subscribe': 'billing',
  'unsubscribe': 'billing',
  'cancel-subscription': 'billing',
  'permission-edit-time': 'behavior',
  'password-protection': 'behavior',
  'skip-work-detail': 'behavior',
  'holiday-setting': 'behavior',
  'memo': 'behavior',
  'slack': 'behavior',
  'screensaver': 'behavior',
  'calc-by-period': 'overview',
  'basic-how-to-use': 'overview',
  'category-pattern-setting': 'settings',
  'closind-date': 'settings',
  'rounding': 'settings',
  'morning-overtime': 'settings',
  'face-recognition-overview': 'settings',
  'face-recognition': 'settings',
  'overnight24': 'settings',
  'overnight1': 'settings',
  'auto-overnight': 'settings',
  'multiple-breaks': 'settings',
  'shifts': 'settings',
  'add-user': 'settings',
  'add-staff': 'settings',
  'display-input-only-account': 'settings',
  'add-edit-staff-from-top': 'settings',
};

const wpSlugToItemCode: Record<string, string> = {
  'calc-by-period': 'M.02',
  'basic-how-to-use': 'M.01',
  'category-pattern-setting': 'S.01',
  'closind-date': 'S.02',
  'rounding': 'S.03',
  'morning-overtime': 'S.04',
  'face-recognition-overview': 'S.05',
  'face-recognition': 'S.06',
  'overnight24': 'S.07',
  'overnight1': 'S.08',
  'auto-overnight': 'S.09',
  'multiple-breaks': 'S.10',
  'shifts': 'S.11',
  'add-user': 'S.12',
  'add-staff': 'S.13',
  'display-input-only-account': 'S.14',
  'permission-edit-time': 'B.01',
  'password-protection': 'B.02',
  'skip-work-detail': 'B.03',
  'holiday-setting': 'B.04',
  'memo': 'B.05',
  'slack': 'B.06',
  'screensaver': 'B.07',
  'subscribe': 'P.01',
  'unsubscribe': 'P.02',
  'cancel-subscription': 'P.03',
};

const wpTitleText = wpPage ? stripHtml(wpPage.title.rendered) : '';
const wpLocalFileKey = wpPage ? (wpSlugToLocalFile[wpPage.slug] ?? wpPage.slug) : '';
const wpLocalMeta = wpPage
  ? localMetaBySlug.get(wpLocalFileKey) ?? localMetaByTitle.get(normalizeManualTitle(wpTitleText))
  : undefined;
const wpFallbackCategory = wpPage ? wpSlugToCategory[wpPage.slug] : undefined;
const resolvedCategory = entry?.data.category ?? mdModule?.frontmatter.category ?? wpLocalMeta?.category ?? wpFallbackCategory;

const updatedDate = isWpManual && wpPage ? new Date(wpPage.modified) : new Date();
const updatedText = new Intl.DateTimeFormat('ja-JP', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit',
})
  .format(updatedDate)
  .replaceAll('/', '.');

const categoryLabel = resolvedCategory ? categoryLabelMap[resolvedCategory] : 'マニュアル';
const categoryEnLabel = resolvedCategory ? categoryEnMap[resolvedCategory] : 'WORDPRESS';

const pageTitle = entry?.data.title ?? mdModule?.frontmatter.title ?? (wpPage ? stripHtml(wpPage.title.rendered) : '');
const pageDescription = cleanManualDescription(
  entry?.data.description
  ?? mdModule?.frontmatter.description
  ?? (wpPage ? buildWpLead(wpPage.excerpt?.rendered || '', wpPage.content?.rendered || '', pageTitle) : ''),
);
const itemCodeText =
  entry?.data.itemCode ??
  mdModule?.frontmatter.itemCode ??
  wpLocalMeta?.itemCode ??
  (wpPage ? wpSlugToItemCode[wpPage.slug] : undefined) ??
  `WP.${String(wpPage?.id ?? '').padStart(4, '0')}`;
const wpContentHtml = wpPage ? localizeWpUploads(wpPage.content.rendered) : '';

const prevLink = isWpManual
  ? prevWpPage
    ? `/manual/${prevWpPage.slug}/`
    : undefined
  : prevEntry
    ? `/manual/${prevEntry.id.replace(/\.md$/, '')}/`
    : undefined;
const prevTitle = isWpManual ? prevWpPage?.title.rendered : prevEntry?.data.title;

const nextLink = isWpManual
  ? nextWpPage
    ? `/manual/${nextWpPage.slug}/`
    : undefined
  : nextEntry
    ? `/manual/${nextEntry.id.replace(/\.md$/, '')}/`
    : undefined;
const nextTitle = isWpManual ? nextWpPage?.title.rendered : nextEntry?.data.title;

const title = `${pageTitle} — マニュアル — ペンギンタイムカード`;
const description = pageDescription;
---

<Layout title={title} description={description}>
  <SiteHeader active="manual" />

  <section class="manual-detail-page">
    <div class="container">
      <nav class="breadcrumb" aria-label="パンくず">
        <a href="/">ホーム</a>
        <span class="sep">/</span>
        <a href="/manual/">マニュアル</a>
        <span class="sep">/</span>
        <span class="here">{pageTitle}</span>
      </nav>

      <header class="doc-head">
        <div class="meta">
          <span class="num">{itemCodeText} / {categoryLabel}</span>
          <span class="cat">{categoryEnLabel}</span>
          <span class="updated">最終更新 {updatedText}</span>
        </div>
        <h1 set:html={isWpManual && wpPage ? wpPage.title.rendered : pageTitle}></h1>
        <p class="lead">{pageDescription}</p>
      </header>

      <div class="doc-grid">
        <article class="doc-body" id="docBody">
          {isWpManual && wpPage ? <div class="wp-body" set:html={wpContentHtml}></div> : Content ? <Content /> : null}

          {(prevLink || nextLink) && (
            <nav class="doc-nav" aria-label="前後のページ">
              {prevLink && prevTitle ? (
                <a class="doc-nav-card prev" href={prevLink}>
                  <span class="dir">← PREV</span>
                  <span class="title" set:html={prevTitle}></span>
                </a>
              ) : (
                <span></span>
              )}

              {nextLink && nextTitle ? (
                <a class="doc-nav-card next" href={nextLink}>
                  <span class="dir">NEXT →</span>
                  <span class="title" set:html={nextTitle}></span>
                </a>
              ) : (
                <span></span>
              )}
            </nav>
          )}
        </article>

        <aside class="doc-toc" aria-label="このページの目次">
          <div class="toc-head">ON THIS PAGE</div>
          <ol id="tocList"></ol>

          <div class="helpful">
            <p>このページは役に立ちましたか？</p>
            <div class="row">
              <button type="button" data-vote="yes">👍 役に立った</button>
              <button type="button" data-vote="no">👎 もう少し</button>
            </div>
          </div>
        </aside>
      </div>

      <div class="back-section">
        <a class="back-link" href="/manual/">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          マニュアル一覧に戻る
        </a>
      </div>
    </div>
  </section>

  <SiteFooter />

  <script>
    const slugify = (value: string) =>
      value
        .toLowerCase()
        .trim()
        .replace(/[^\w\u3040-\u30ff\u3400-\u9fbf\s-]/g, '')
        .replace(/\s+/g, '-');

    const docBody = document.getElementById('docBody');
    const tocList = document.getElementById('tocList');

    if (docBody && tocList) {
      const headings = Array.from(docBody.querySelectorAll('h2, h3'));

      headings.forEach((heading, index) => {
        if (!heading.id) {
          const seed = slugify(heading.textContent || 'section');
          heading.id = seed ? `${seed}-${index + 1}` : `section-${index + 1}`;
        }

        const li = document.createElement('li');
        const a = document.createElement('a');
        a.href = `#${heading.id}`;
        a.textContent = heading.textContent || '';
        if (heading.tagName.toLowerCase() === 'h3') {
          a.classList.add('toc-subitem');
        }
        li.appendChild(a);
        tocList.appendChild(li);
      });

      const tocLinks = Array.from(tocList.querySelectorAll('a'));
      const setActiveToc = (id: string) => {
        tocLinks.forEach((a) => {
          a.classList.toggle('active', a.getAttribute('href') === id);
        });
      };

      if (tocLinks.length > 0) {
        tocLinks[0].classList.add('active');
      }
      const sections = tocLinks
        .map((a) => document.getElementById(a.getAttribute('href')?.replace('#', '') || ''))
        .filter((item): item is HTMLElement => Boolean(item));

      if (sections.length > 0) {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entryItem) => {
              if (!entryItem.isIntersecting) {
                return;
              }

              const id = `#${entryItem.target.id}`;
              setActiveToc(id);
            });
          },
          { rootMargin: '-30% 0px -60% 0px' },
        );

        sections.forEach((section) => obs.observe(section));

        const updateActiveByScroll = () => {
          const offset = 140;
          const current = [...sections]
            .reverse()
            .find((section) => window.scrollY + offset >= section.offsetTop);
          if (current instanceof HTMLElement) {
            setActiveToc(`#${current.id}`);
          }
        };

        window.addEventListener('scroll', updateActiveByScroll, { passive: true });
        updateActiveByScroll();
      }
    }

    // Wrap tables in scroll containers
    document.querySelectorAll('#docBody table').forEach((table) => {
      if (!table.parentElement?.classList.contains('table-scroll-wrap')) {
        const wrapper = document.createElement('div');
        wrapper.className = 'table-scroll-wrap';
        table.parentNode?.insertBefore(wrapper, table);
        wrapper.appendChild(table);
      }
    });

    document.querySelectorAll('.helpful button').forEach((button) => {
      button.addEventListener('click', () => {
        document.querySelectorAll('.helpful button').forEach((node) => node.classList.remove('picked'));
        button.classList.add('picked');
      });
    });
  </script>
</Layout>

