<script>
	const input = document.getElementById('searchInput');
	const cards = document.querySelectorAll('.manual-card');
	const blocks = document.querySelectorAll('.manual-cat-block');

	if (input instanceof HTMLInputElement) {
		input.addEventListener('input', () => {
			const q = input.value.trim().toLowerCase();
			cards.forEach((c) => {
				const txt = ((c.textContent || '') + ' ' + (c.getAttribute('data-keywords') || '')).toLowerCase();
				c.classList.toggle('hidden', Boolean(q && !txt.includes(q)));
			});
			blocks.forEach((b) => {
				const visible = b.querySelectorAll('.manual-card:not(.hidden)').length;
				b.classList.toggle('hidden', visible === 0);
			});
		});
	}

	document.addEventListener('keydown', (e) => {
		if (!input) return;
		if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
			e.preventDefault();
			input.focus();
		}
	});

	const revealObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (!entry.isIntersecting) {
					return;
				}
				entry.target.classList.add('in');
				revealObserver.unobserve(entry.target);
			});
		},
		{ threshold: 0.18 },
	);

	document.querySelectorAll('.reveal').forEach((el) => revealObserver.observe(el));
</script>
