---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import PageCta from '../components/PageCta.astro';

const WP_MANUAL_ENDPOINT = 'https://tc-timecard.com/wp-json/wp/v2/pages?parent=2887&per_page=100';

const stripHtml = (html: string) => html.replace(/<[^>]*>/g, ' ').replace(/\s+/g, ' ').trim();

const decodeEntities = (text: string) =>
	text
		.replaceAll('&nbsp;', ' ')
		.replaceAll('&#8230;', '…')
		.replaceAll('&hellip;', '…')
		.replaceAll('&amp;', '&')
		.replaceAll('&quot;', '"')
		.replaceAll('&#039;', "'");

const tidyWpText = (html: string) =>
	decodeEntities(stripHtml(html))
		.replace(/\[\s*…\s*\]\s*続きを読む\s*/gi, '')
		.replace(/続きを読む\s*/gi, '')
		.replace(/\s*\(続きを読む\)\s*/gi, '')
		.replace(/\s*read\s+more\s*$/gi, '')
		.replace(/(\.\.\.|…)\s*$/g, '')
		.replace(/\s+/g, ' ')
		.trim();

const getFirstSentence = (text: string) => {
	const normalized = text.trim();
	if (!normalized) {
		return '';
	}

	const jp = normalized.indexOf('。');
	if (jp >= 0) {
		return normalized.slice(0, jp + 1);
	}

	const en = normalized.search(/[.!?！？]/);
	if (en >= 0) {
		return normalized.slice(0, en + 1);
	}

	return normalized;
};

const toCardDescription = (text: string, maxLength = 46) => {
	const normalized = tidyWpText(text);
	if (!normalized) {
		return 'マニュアル詳細をご覧ください。';
	}

	const firstSentence = getFirstSentence(normalized);
	if (firstSentence.length <= maxLength) {
		return firstSentence;
	}

	const clipped = firstSentence.slice(0, maxLength);
	const splitPos = Math.max(clipped.lastIndexOf('、'), clipped.lastIndexOf(' '));
	if (splitPos >= Math.floor(maxLength * 0.55)) {
		const head = clipped.slice(0, splitPos).trim();
		return /[。.!?！？]$/.test(head) ? head : `${head}。`;
	}

	return `${clipped.trim().replace(/[、,]$/, '')}…`;
};

const extractContentBlocks = (html: string) => {
	const blockMatches = [...html.matchAll(/<(p|li|h2|h3)[^>]*>([\s\S]*?)<\/\1>/gi)];
	const blocks = blockMatches
		.map((match) => tidyWpText(match[2]))
		.filter((text) => text.length > 0);

	if (blocks.length > 0) {
		return blocks;
	}

	const fallback = tidyWpText(html);
	return fallback ? [fallback] : [];
};

const removeTitlePrefix = (text: string, title: string) => {
	if (!title) return text;
	const safe = title.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
	return text.replace(new RegExp(`^${safe}\\s*`, 'i'), '').trim();
};

const extractH2Topics = (contentHtml: string, pageTitle: string) => {
	const titleNormalized = tidyWpText(pageTitle).replace(/\s+/g, '');
	const h2Matches = [...contentHtml.matchAll(/<h2[^>]*>([\s\S]*?)<\/h2>/gi)];
	const h2Topics = h2Matches
		.map((match) => tidyWpText(match[1]))
		.map((text) => text.replace(/^\d+[\.．、)）]?\s*/, '').trim())
		.filter((text) => text.length >= 2)
		.filter((text) => text.replace(/\s+/g, '') !== titleNormalized)
		.filter((text, index, arr) => arr.indexOf(text) === index);

	if (h2Topics.length >= 2) {
		return h2Topics;
	}

	const allMatches = [...contentHtml.matchAll(/<(h2|h3)[^>]*>([\s\S]*?)<\/\1>/gi)];
	return allMatches
		.map((match) => tidyWpText(match[2]))
		.map((text) => text.replace(/^\d+[\.．、)）]?\s*/, '').trim())
		.filter((text) => text.length >= 2)
		.filter((text) => text.replace(/\s+/g, '') !== titleNormalized)
		.filter((text, index, arr) => arr.indexOf(text) === index);
};

const isMetadataLine = (text: string) =>
	/^(所要時間|バージョン|更新日時|最終更新|作成日|January|February|March|April|May|June|July|August|September|October|November|December|\d{4}年\d{1,2}月|版|v\d+\.\d+)/.test(
		text
	);

const isGenericTopic = (topic: string) => /^(注意点|注意|設定|方法|手順|やり方|確認|一覧|基本|詳細|その他)$/.test(topic);

const buildWpCoreDescription = (_excerptHtml: string, contentHtml: string, pageTitle: string) => {
	const topics = extractH2Topics(contentHtml, pageTitle);

	const spread: string[] = [];
	if (topics.length >= 1) spread.push(topics[0]);
	if (topics.length >= 3) spread.push(topics[Math.floor((topics.length - 1) / 2)]);
	if (topics.length >= 2) spread.push(topics[topics.length - 1]);
	const unique = spread.filter((t, i, a) => a.indexOf(t) === i);

	if (unique.length >= 3) {
		const topicList = unique.slice(0, 3).join('・');
		return `${topicList}など、関連する操作・設定を確認できます。`;
	}

	if (unique.length === 2) {
		const [a, b] = unique;
		return `${a}と${b}をまとめて確認できます。`;
	}

	if (unique.length === 1) {
		const topic = unique[0];
		if (isGenericTopic(topic)) {
			return `${pageTitle}の${topic}について詳しく確認できます。`;
		}
		return `${topic}について詳しく確認できます。`;
	}

	const titleText = tidyWpText(pageTitle);
	const pMatches = [...contentHtml.matchAll(/<p[^>]*>([\s\S]*?)<\/p>/gi)];
	const validParas: string[] = [];
	for (const [, inner] of pMatches) {
		const raw = removeTitlePrefix(tidyWpText(inner), titleText);
		if (raw.length < 20) continue;
		if (isMetadataLine(raw)) continue;
		if (/^(まず[、,]|次に[、,]|\d+[.、)）]|[①②③④⑤⑥⑦⑧⑨])/.test(raw)) continue;
		validParas.push(raw);
	}

	if (validParas.length >= 2) {
		const combined = validParas.slice(0, 3).join('');
		if (combined.length > 30) {
			return combined;
		}
	}

	if (validParas.length > 0) {
		const sorted = [...validParas].sort((a, b) => b.length - a.length);
		for (const para of sorted) {
			const jp = para.indexOf('。');
			if (jp > 16) return para.slice(0, jp + 1);
			if (para.length >= 20) return para;
		}
	}

	return `「${pageTitle}」の設定手順と使い方をまとめています。`;
};

const buildWpListDescription = (excerptHtml: string, contentHtml: string, pageTitle: string) => {
	const core = buildWpCoreDescription(excerptHtml, contentHtml, pageTitle);
	const withoutPrefix = core.replace(/^このページでは、?\s*/, '').trim();
	const normalized = withoutPrefix.replace(/。{2,}$/g, '。');
	return toCardDescription(normalized);
};

type WpPage = {
	id: number;
	slug: string;
	menu_order: number;
	date: string;
	title: { rendered: string };
	excerpt: { rendered: string };
	content: { rendered: string };
};

type ManualCategory = 'overview' | 'settings' | 'behavior' | 'billing';

type ManualListItem = {
	slug: string;
	title: string;
	description: string;
	category: ManualCategory;
	itemCode: string;
	keywords: string[];
	isNew: boolean;
	popular: boolean;
	order: number;
};

const fetchWpManualPages = async (): Promise<WpPage[]> => {
	try {
		const response = await fetch(WP_MANUAL_ENDPOINT, {
			headers: { Accept: 'application/json' },
		});

		if (!response.ok) {
			return [];
		}

		const payload = (await response.json()) as unknown;
		if (!Array.isArray(payload)) {
			return [];
		}

		return payload as WpPage[];
	} catch {
		return [];
	}
};

const title = 'マニュアル — ペンギンタイムカード';
const description = 'ペンギンタイムカードの使い方、機能説明などのマニュアル';

const categoryMeta = [
  { key: 'overview', num: '01', en: 'OVERVIEW', ja: '概要' },
  { key: 'settings', num: '02', en: 'SETTINGS', ja: '設定' },
  { key: 'behavior', num: '03', en: 'BEHAVIOR', ja: '動作関連' },
  { key: 'billing', num: '04', en: 'BILLING', ja: 'お支払い・解約' },
] as const;

const categoryCodePrefixMap: Record<ManualCategory, string> = {
	overview: 'M',
	settings: 'S',
	behavior: 'B',
	billing: 'P',
};

const wpSlugToLocalFile: Record<string, string> = {
	'auto-overnight': 'auto-next-day',
	'face-recognition-overview': 'face-auth-overview',
	'face-recognition': 'face-auth',
	'add-user': 'owner-account',
	'add-staff': 'staff-account',
	'display-input-only-account': 'limited-account',
	'permission-edit-time': 'lock-edit-time',
	'skip-work-detail': 'skip-detail-after-stamp',
	'password-protection': 'admin-password',
	'holiday-setting': 'holiday-settings',
	'morning-overtime': 'early-overtime',
	'closind-date': 'closing-day',
	'rounding': 'rounding',
	'unsubscribe': 'delete-account',
	'cancel-subscription': 'cancel-subscription',
	'subscribe': 'billing',
	'basic-how-to-use': 'basic-usage',
	'multiple-breaks': 'multi-break',
	'shifts': 'shift-management',
	'overnight24': 'open-24h',
	'overnight1': 'midnight-operation',
	'slack': 'slack-integration',
	'category-pattern-setting': 'category-patterns',
	'memo': 'memo-feature',
	'screensaver': 'screensaver',
};

const wpSlugToCategory: Record<string, ManualCategory> = {
	'subscribe': 'billing',
	'unsubscribe': 'billing',
	'cancel-subscription': 'billing',
	'permission-edit-time': 'behavior',
	'password-protection': 'behavior',
	'skip-work-detail': 'behavior',
	'holiday-setting': 'behavior',
	'memo': 'behavior',
	'slack': 'behavior',
	'screensaver': 'behavior',
	'calc-by-period': 'overview',
	'basic-how-to-use': 'overview',
	'category-pattern-setting': 'settings',
	'closind-date': 'settings',
	'rounding': 'settings',
	'morning-overtime': 'settings',
	'face-recognition-overview': 'settings',
	'face-recognition': 'settings',
	'overnight24': 'settings',
	'overnight1': 'settings',
	'auto-overnight': 'settings',
	'multiple-breaks': 'settings',
	'shifts': 'settings',
	'add-user': 'settings',
	'add-staff': 'settings',
	'display-input-only-account': 'settings',
	'add-edit-staff-from-top': 'settings',
};

const normalizeManualTitle = (text: string) =>
	tidyWpText(text)
		.replace(/（概要）/g, 'の概要')
		.replace(/\(概要\)/g, 'の概要')
		.replace(/\s+/g, '')
		.trim();

const localEntries = (await getCollection('manual')).sort((a, b) => a.data.order - b.data.order);
const localMetaBySlug = new Map(
	localEntries.map((entry) => [
		entry.id.replace(/\.md$/, ''),
		{
			category: entry.data.category,
			itemCode: entry.data.itemCode,
			keywords: entry.data.keywords,
			isNew: entry.data.isNew,
			popular: entry.data.popular,
			order: entry.data.order,
			description: entry.data.description,
		},
	]),
);

const localMetaByTitle = new Map(
	localEntries.map((entry) => [
		normalizeManualTitle(entry.data.title),
		{
			category: entry.data.category,
			itemCode: entry.data.itemCode,
			keywords: entry.data.keywords,
			isNew: entry.data.isNew,
			popular: entry.data.popular,
			order: entry.data.order,
			description: entry.data.description,
		},
	]),
);

const wpPages = (await fetchWpManualPages()).sort((a, b) => {
	const leftOrder = typeof a.menu_order === 'number' ? a.menu_order : 0;
	const rightOrder = typeof b.menu_order === 'number' ? b.menu_order : 0;
	if (leftOrder !== rightOrder) {
		return leftOrder - rightOrder;
	}

	return new Date(a.date).getTime() - new Date(b.date).getTime();
});

const manualItems: ManualListItem[] = wpPages.length
	? wpPages.map((page, index) => {
			const titleText = stripHtml(page.title?.rendered ?? '');
			const localFileKey = wpSlugToLocalFile[page.slug] || page.slug;
			const localMeta = localMetaBySlug.get(localFileKey) ?? localMetaByTitle.get(normalizeManualTitle(titleText));
			const fallbackCategory = wpSlugToCategory[page.slug] ?? 'overview';
			const wpDescription = buildWpListDescription(page.excerpt?.rendered ?? '', page.content?.rendered ?? '', titleText);

			return {
				slug: page.slug,
				title: titleText,
				description: toCardDescription(localMeta?.description || wpDescription),
				category: localMeta?.category ?? fallbackCategory,
				itemCode: localMeta?.itemCode ?? `WP.${String(page.id).padStart(4, '0')}`,
				keywords: localMeta?.keywords ?? titleText.split(/\s+/).filter(Boolean),
				isNew: localMeta?.isNew ?? false,
				popular: localMeta?.popular ?? false,
				order: localMeta?.order ?? (typeof page.menu_order === 'number' ? page.menu_order : index + 1),
			};
		})
	: localEntries.map((entry) => ({
			slug: entry.id.replace(/\.md$/, ''),
			title: entry.data.title,
			description: toCardDescription(entry.data.description),
			category: entry.data.category,
			itemCode: entry.data.itemCode,
			keywords: entry.data.keywords,
			isNew: entry.data.isNew,
			popular: entry.data.popular,
			order: entry.data.order,
		}));

const sortedManualItems = [...manualItems].sort((a, b) => a.order - b.order);
const grouped = categoryMeta
  .map((cat) => {
		const items = sortedManualItems.filter((item) => item.category === cat.key);
		const prefix = categoryCodePrefixMap[cat.key as ManualCategory];
		return {
			...cat,
			items: items.map((item, index) => ({
				...item,
				displayCode: `${prefix}.${String(index + 1).padStart(2, '0')}`,
			})),
		};
	})
  .filter((cat) => cat.items.length > 0);
---

<Layout title={title} description={description}>
	<SiteHeader active="manual" />

	<section class="manual-hero" data-screen-label="02 Manual Hero">
		<div class="container">
			<div class="breadcrumb">
				<a href="/">ホーム</a>
				<span class="sep">/</span>
				<span class="here">マニュアル</span>
			</div>

			<div class="manual-hero-grid" style="margin-top: 30px;">
				<div>
					<span class="eyebrow">USER MANUAL</span>
					<h1>
						わからないこと、<br/>
						<span class="accent">ぜんぶここで</span>。
					</h1>
					<p class="lead">
						基本の使い方から、ちょっと応用な設定まで。<br/>
						下記リンクをクリックして、知りたいページにジャンプしてください。マニュアルは順次追加中です。
					</p>
					<a class="blue-link" href="/news/category/manual/">
						<span class="dot"></span>
						ブルー版のマニュアルはこちら →
					</a>

					<div class="manual-search">
						<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
						<input id="searchInput" type="text" placeholder="マニュアルを検索（例: 残業、丸め、シフト...）" />
						<kbd>⌘K</kbd>
					</div>
				</div>

				<div class="manual-hero-card">
					<div class="stack">
						<div class="mock-doc">
							<div class="badge">01</div>
							<div class="lines"><div class="l1"></div><div class="l2"></div></div>
						</div>
						<div class="mock-doc">
							<div class="badge">02</div>
							<div class="lines"><div class="l1" style="width: 70%;"></div><div class="l2" style="width: 45%;"></div></div>
						</div>
						<div class="mock-doc">
							<div class="badge">03</div>
							<div class="lines"><div class="l1" style="width: 85%;"></div><div class="l2" style="width: 60%;"></div></div>
						</div>
						<div class="mock-doc">
							<div class="badge">04</div>
							<div class="lines"><div class="l1" style="width: 65%;"></div><div class="l2" style="width: 40%;"></div></div>
						</div>
					</div>
					<img class="penguin-peek" src="/assets/penguin.png" alt="" />
				</div>
			</div>
		</div>
	</section>

	<section style="padding: 0;">
		<div class="container">
			<div class="manual-notice">
				<span class="icon">!</span>
				<span>マニュアルは順次追加中です。お探しの内容が見つからない場合は、お気軽にお問い合わせください。</span>
				<small>最終更新 2024.05.20</small>
			</div>
		</div>
	</section>

	{grouped.map((group) => (
		<section class="manual-section">
			<div class="container manual-cat-block" data-cat={group.ja}>
				<div class="manual-cat-head">
					<div class="num">{group.num}</div>
					<h2>
						<small>{group.en}</small>
						{group.ja}
					</h2>
					<div class="count">{group.items.length} articles</div>
				</div>

				<div class="manual-grid">
					{group.items.map((item) => (
						<a class="manual-card" href={`/manual/${item.slug}/`} data-keywords={item.keywords.join(' ')}>
							<div class="row">
								<span class="num">{item.displayCode}</span>
								{item.popular ? <span class="new">人気</span> : item.isNew ? <span class="new">NEW</span> : null}
							</div>
							<h3>{item.title}</h3>
							<p>{item.description}</p>
							<div class="arrow">
								<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	))}

	<PageCta
		eyebrow="CONTACT"
		title="解決しないときは、お気軽に"
		description="マニュアルを読んでも分からないことがあれば、お問い合わせフォームからご相談ください。<br/>担当者から、できるだけ早くお返事します。"
		buttonText="お問い合わせフォーム"
		buttonHref="/contact-us/"
		meta="よくある質問もぜひご覧ください"
		screenLabel="08 CTA"
	/>

	<SiteFooter />
</Layout>

<style>
	.manual-hero {
		position: relative;
		padding: 70px 0 80px;
		overflow: hidden;
		background:
			radial-gradient(ellipse 70% 50% at 80% 30%, rgba(243, 154, 45, 0.14), transparent 60%),
			radial-gradient(ellipse 50% 40% at 15% 80%, rgba(123, 200, 232, 0.18), transparent 60%);
	}
	.manual-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
		gap: 40px;
		align-items: center;
	}
	@media (max-width: 820px) {
		.manual-hero-grid { grid-template-columns: 1fr; }
	}
	.manual-hero h1 {
		font-size: clamp(34px, 4.6vw, 54px);
		letter-spacing: -0.01em;
		margin: 16px 0 22px;
	}
	.manual-hero h1 .accent {
		color: var(--brand-deep);
		position: relative;
		display: inline-block;
	}
	.manual-hero h1 .accent::after {
		content: "";
		position: absolute;
		left: 0; right: 0; bottom: -4px;
		height: 8px;
		background: var(--brand-soft);
		border-radius: 999px;
		z-index: -1;
	}
	.manual-hero p.lead {
		font-size: 18px;
		color: var(--ink-2);
		max-width: 560px;
		margin: 0 0 24px;
	}
	.manual-hero .blue-link {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		background: white;
		border: 1.5px solid var(--line);
		border-radius: 999px;
		padding: 10px 18px;
		font-size: 14px;
		font-weight: 700;
		color: var(--ink);
		box-shadow: 0 5px 0 var(--line);
		transition: transform .25s, box-shadow .25s;
	}
	.blue-link:hover { transform: translateY(-2px); }
	.blue-link .dot { width: 10px; height: 10px; border-radius: 50%; background: var(--sky); }

	.manual-search {
		margin-top: 30px;
		background: white;
		border-radius: 18px;
		border: 1px solid var(--line);
		padding: 14px 18px;
		display: flex;
		align-items: center;
		gap: 12px;
		box-shadow: var(--shadow);
		max-width: 520px;
	}
	.manual-search svg { color: var(--brand-deep); flex: none; }
	.manual-search input {
		border: none;
		outline: none;
		flex: 1;
		font-family: inherit;
		font-size: 16px;
		font-weight: 600;
		color: var(--ink);
		background: transparent;
	}
	.manual-search input::placeholder { color: var(--ink-2); opacity: 0.7; }
	.manual-search kbd {
		font-family: "JetBrains Mono", monospace;
		font-size: 11px;
		font-weight: 700;
		background: var(--cream);
		border: 1px solid var(--line);
		border-bottom-width: 2px;
		border-radius: 6px;
		padding: 3px 7px;
		color: var(--ink-2);
	}

	.manual-hero-card {
		position: relative;
		aspect-ratio: 1 / 1;
		background: white;
		border-radius: 28px;
		border: 1px solid var(--line);
		box-shadow: var(--shadow-lg);
		padding: 26px;
		overflow: hidden;
	}
	.manual-hero-card::before {
		content: "";
		position: absolute;
		inset: 0;
		background:
			repeating-linear-gradient(0deg, transparent 0 28px, rgba(239, 226, 203, 0.5) 28px 29px),
			repeating-linear-gradient(90deg, transparent 0 28px, rgba(239, 226, 203, 0.5) 28px 29px);
		pointer-events: none;
	}
	.manual-hero-card .stack {
